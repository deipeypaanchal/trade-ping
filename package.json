{
  "name": "tradeping-bot",
  "version": "0.2.0",
  "private": true,
  "license": "MIT",
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "corepack pnpm --filter @tradeping/api dev",
    "build": "corepack pnpm --filter @tradeping/api build",
    "start": "corepack pnpm --filter @tradeping/api start",
    "test": "corepack pnpm --filter @tradeping/api test",
    "db:generate": "corepack pnpm --filter @tradeping/api prisma:generate",
    "db:migrate": "corepack pnpm --filter @tradeping/api prisma:migrate",
    "db:deploy": "corepack pnpm --filter @tradeping/api prisma:deploy",
    "lint": "corepack pnpm --filter @tradeping/api lint"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "prisma": "^6.1.0"
  },
  "pnpm": {
    "overrides": {
      "axios": "^1.15.2",
      "lodash": "^4.18.1",
      "multer": "^2.1.1"
    }
  },
  "engines": {"node": ">=20"},
  "packageManager": "pnpm@9.15.0"
}

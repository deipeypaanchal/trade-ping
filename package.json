{
  "name": "tradeping-bot",
  "version": "0.2.0",
  "private": true,
  "license": "MIT",
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "corepack pnpm --filter @tradeping/api dev",
    "build": "corepack pnpm --filter @tradeping/api build",
    "start": "corepack pnpm --filter @tradeping/api start",
    "test": "corepack pnpm --filter @tradeping/api test",
    "db:generate": "corepack pnpm --filter @tradeping/api prisma:generate",
    "db:migrate": "corepack pnpm --filter @tradeping/api prisma:migrate",
    "db:deploy": "corepack pnpm --filter @tradeping/api prisma:deploy",
    "db:backup": "scripts/pg-backup.sh",
    "lint": "corepack pnpm --filter @tradeping/api lint",
    "railway:recover": "scripts/railway-recover.sh",
    "scripts:check": "bash -n scripts/*.sh"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "prisma": "^6.1.0"
  },
  "pnpm": {
    "overrides": {
      "axios": "^1.18.1",
      "file-type": "^21.3.2",
      "form-data": "^4.0.6",
      "glob": "^10.5.0",
      "lodash": "^4.18.1",
      "multer": "^2.2.0",
      "picomatch": "^4.0.4",
      "qs": "^6.15.2",
      "tmp": "^0.2.4",
      "webpack": "^5.104.1"
    }
  },
  "engines": {"node": ">=20"},
  "packageManager": "pnpm@9.15.0"
}

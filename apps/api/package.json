{
  "name": "@tradeping/api",
  "version": "0.2.0",
  "private": true,
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "dev": "nest start --watch",
    "build": "prisma generate --schema ../../prisma/schema.prisma && nest build",
    "start": "node dist/main.js",
    "test": "jest --runInBand",
    "lint": "eslint src",
    "audit": "pnpm audit --audit-level=high --prod",
    "prisma:generate": "prisma generate --schema ../../prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema ../../prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema ../../prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.23",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.23",
    "@nestjs/platform-express": "^11.1.23",
    "@prisma/client": "^6.1.0",
    "bottleneck": "^2.19.5",
    "bullmq": "^5.34.7",
    "express": "^5.2.1",
    "ioredis": "^5.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "snaptrade-typescript-sdk": "9.0.200",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.23",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "eslint": "^10.4.0",
    "globals": "^15.14.0",
    "jest": "^30.4.2",
    "prisma": "^6.1.0",
    "ts-jest": "^29.2.5",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.18.2"
  }
}

NODE_ENV=development
PORT=3000
APP_BASE_URL=https://your-domain.com
DATABASE_URL=postgresql://tradeping:tradeping@localhost:5432/tradeping?schema=public
REDIS_URL=redis://localhost:6379

TELEGRAM_BOT_TOKEN=123456:replace_me
TELEGRAM_BOT_USERNAME=tradeping_v1_bot
TELEGRAM_WEBHOOK_SECRET=replace_with_random_A-Za-z0-9_-_secret
INTERNAL_JOB_SECRET=replace_with_at_least_32_random_chars

SNAPTRADE_CLIENT_ID=replace_me
SNAPTRADE_CONSUMER_KEY=replace_me
SNAPTRADE_REDIRECT_URI=https://your-domain.com/snaptrade/callback
SNAPTRADE_BROKER_SLUG=
SNAPTRADE_USE_MOCK=false

# 32 bytes, base64. Generate with: node scripts/generate-key.js
ENCRYPTION_KEY_BASE64=replace_with_32_byte_base64_key

# Sync tuning. Keep conservative until SnapTrade approves real-time access.
TRADE_ORDER_LOOKBACK_DAYS=3
SYNC_INTERVAL_MINUTES=5
BACKFILL_SUPPRESS_HOURS=24

# Optional deploy metadata shown in /healthz and /livez.
RELEASE_SHA=
